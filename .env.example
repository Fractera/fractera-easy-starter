# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=                          # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_RESEND_FROM=noreply@fractera.ai
RESEND_API_KEY=

# ── Database (Neon) ────────────────────────────────────────────────────────────
DATABASE_URL=                         # postgres://...neon.tech/...?sslmode=require

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...        # $25/month recurring
STRIPE_PRICE_ANNUAL=price_...         # $190/year recurring

# ── Contabo API (https://my.contabo.com/api/details) ─────────────────────────
CONTABO_CLIENT_ID=
CONTABO_CLIENT_SECRET=
CONTABO_API_USER=                     # your Contabo login email
CONTABO_API_PASSWORD=                 # API password from Contabo panel (separate from login)
CONTABO_PRODUCT_ID=V45                # Cloud VPS 10 — €4.50/mo (4 vCPU, 8 GB, 75 GB NVMe)
CONTABO_IMAGE_ID=                     # Ubuntu 24.04 image UUID — get from Contabo panel
CONTABO_REGION=EU

# ── Contabo affiliate (public — surfaced on landing /pricing and /partners) ──
# When Contabo approves us as an affiliate, paste the referral URL here.
# Until approved, fallback below points to Cloud VPS 10 / Ubuntu 24.04 product page.
# Note: NEXT_PUBLIC_* is baked into the client bundle at `next build` — Vercel rebuild required after change.
NEXT_PUBLIC_CONTABO_AFFILIATE_URL=    # fallback: https://contabo.com/en/vps/cloud-vps-10/?image=ubuntu.332&qty=1&contract=12&storage-type=cloud-vps-10-150-gb-ssd

# ── One-click deploy server (fallback / test only) ────────────────────────────
FRACTERA_DEPLOY_IP=
FRACTERA_DEPLOY_USER=root
FRACTERA_DEPLOY_PASSWORD=

# ── NextAuth URL ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://fractera-easy-starter.vercel.app

# ── Existing ──────────────────────────────────────────────────────────────────
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
INSTALL_SCRIPT_SECRET=

# ── Cloudflare Origin Certificate (replaces Let's Encrypt — no rate limits) ──
# Generate at: Cloudflare Dashboard → SSL/TLS → Origin Server → Create Certificate
# Hostnames: *.fractera.ai, *.*.fractera.ai   Validity: 15 years
# Set Cloudflare SSL mode to "Full (strict)" after adding the cert
CF_ORIGIN_CERT=
CF_ORIGIN_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── i18n ──────────────────────────────────────────────────────────────────────
# Comma-separated list of enabled language codes (ISO 639-1).
# Single value = SINGLE_LANG_MODE (hides /lang/ segment from URLs).
NEXT_PUBLIC_SUPPORTED_LANGUAGES=en,fr,es,pt,de,it,nl,sv,no,da,fi,is,el,pl,cs,sk,hu,ro,hr,sl,et,lv,lt,mt,ca,gl,cy,ga,eu,ru,uk,be,bg,sr,bs,mk,sq,kk,uz,ky,tg,tk,az,hy,ka,mn,ar,tr,he,fa,ku,af,sw,ha,yo,ig,am,zu,xh,rw,so,zh,ja,ko,hi,ur,bn,te,mr,kn,gu,ml,ta,ne,vi,th,id,ms,tl,my,km,lo
# Must be one of the codes above. Fallback shown when translation is missing.
NEXT_PUBLIC_DEFAULT_LOCALE=en
