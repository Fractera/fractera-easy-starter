generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  email               String?        @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  createdAt           DateTime       @default(now())
  referredByPartnerId String?
  accounts            Account[]
  sessions            Session[]
  subscriptions       Subscription[]
  serverTokens        ServerToken[]
  vpsReserves         VpsReserve[]
  purchases           Purchase[]
  sponsorships        Sponsorship[]
  partner             Partner?       @relation("PartnerSelf")
  referredBy          Partner?       @relation("PartnerReferrals", fields: [referredByPartnerId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String        @id @default(cuid())
  userId               String
  stripeSubscriptionId String?       @unique
  stripeCustomerId     String
  stripePaymentIntentId String?      @unique
  status               String        // active | cancelled | past_due | trialing
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  planId               String        @default("monthly") // trial | monthly | annual
  createdAt            DateTime      @default(now())
  user                 User          @relation(fields: [userId], references: [id])
  serverTokens         ServerToken[]
}

model ServerToken {
  id                String        @id @default(cuid())
  token             String        @unique @default(cuid())
  userId            String
  subscriptionId    String?
  subdomain         String?
  deploySessionId   String?
  lastPingAt        DateTime?
  status            String        @default("pending") // pending | provisioning | queued | active | offline | error
  statusData        Json?
  deployError       String?       // текст ошибки SSH/bootstrap
  warningSentAt     DateTime?
  createdAt         DateTime      @default(now())
  stripeCheckoutSessionId String?
  contaboInstanceId String?
  serverIp          String?
  serverPassword    String?
  whiteLabelActive  Boolean       @default(false)
  user              User          @relation(fields: [userId], references: [id])
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  purchases         Purchase[]
}

model Purchase {
  id              String       @id @default(cuid())
  userId          String
  serverTokenId   String?
  productType     String       // "white_label"
  stripePaymentId String       @unique
  serverIp        String?
  serverSubdomain String?
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id])
  serverToken     ServerToken? @relation(fields: [serverTokenId], references: [id])
}


model Sponsorship {
  id                   String    @id @default(cuid())
  userId               String
  tier                 String    // "s1" | "s5" | "s20"
  stripeCustomerId     String
  stripeSubscriptionId String    @unique
  status               String    // active | canceled | past_due | unpaid | incomplete
  firstPaymentAt       DateTime?
  lastPaymentAt        DateTime?
  paymentsCount        Int       @default(0)
  createdAt            DateTime  @default(now())
  user                 User      @relation(fields: [userId], references: [id])

  @@index([tier, status])
}

model Partner {
  id        String        @id @default(cuid())
  userId    String        @unique
  slug      String        @unique // auto-generated, e.g. happy-fox-42 — future personal subdomain
  status    String        @default("active") // active | suspended (auto-approve at registration)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation("PartnerSelf", fields: [userId], references: [id], onDelete: Cascade)
  links     PartnerLink[]
  referrals User[]        @relation("PartnerReferrals")
}

model PartnerLink {
  id           String   @id @default(cuid())
  partnerId    String
  providerName String   // user-supplied label, surfaced on widget/mirror (e.g. "Contabo")
  affiliateUrl String   // full affiliate URL from the provider's program
  isDefault    Boolean  @default(false) // exactly one default per partner (enforced in app layer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
}

model VpsReserve {
  id                        String    @id @default(cuid())
  ip                        String
  login                     String    @default("root")
  password                  String
  subdomain                 String?   // set after bootstrap completes
  provisioningServerTokenId String?   // temp ServerToken used during pool bootstrap
  status                    String    @default("available") // available | provisioning | ready | pending_payment | paid
  reservedUntil             DateTime? // when the checkout session expires (auto-released by webhook)
  assignedUserId            String?
  assignedAt                DateTime?
  paidAt                    DateTime?
  createdAt                 DateTime  @default(now())
  user                      User?     @relation(fields: [assignedUserId], references: [id])
}
